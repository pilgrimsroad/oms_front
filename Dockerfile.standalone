# 1단계: 빌드
FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
ENV VITE_API_URL=
RUN npm run build

# 2단계: nginx (독립 실행 - host.docker.internal 프록시)
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.standalone.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
